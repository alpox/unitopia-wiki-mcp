# Copy to .env to override defaults when running on the host (npm run dev).
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen3:latest
EMBED_MODEL=nomic-embed-text
PORT=8080
TOP_K=6
INDEX_DIR=./index
# Root of the crawled OKF knowledge bundle.
KB_DIR=../knowledgebase/unitopia
# Source MediaWiki (HTTP-only, expired TLS cert).
WIKI_BASE_URL=http://unitopia.intelligense.de
SERVED_MODEL_ID=qwen3-unitopia-rag
# Set to true to let qwen3 emit its <think> reasoning stream.
THINK=false
MAX_HISTORY_MESSAGES=10
# Max chars of the latest user message used as the retrieval query.
MAX_QUERY_CHARS=1200
